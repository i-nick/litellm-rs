apiVersion: v1
kind: Secret
metadata:
  name: litellm-gateway-secrets
  namespace: litellm-gateway
  labels:
    app.kubernetes.io/name: litellm-gateway
    app.kubernetes.io/component: secrets
type: Opaque
stringData:
  # ===========================================
  # IMPORTANT: Copy this file to secret.yaml
  # and replace all placeholder values with
  # your actual credentials before applying.
  # DO NOT commit secret.yaml to version control!
  # ===========================================

  # Database connection
  DATABASE_URL: "postgresql://gateway:YOUR_DB_PASSWORD@postgres-service:5432/gateway"
  REDIS_URL: "redis://:YOUR_REDIS_PASSWORD@redis-service:6379"

  # JWT secret (generate with: openssl rand -base64 32)
  JWT_SECRET: "GENERATE_A_STRONG_SECRET_KEY"

  # Provider API keys (only include the ones you need)
  OPENAI_API_KEY: ""
  ANTHROPIC_API_KEY: ""
  GOOGLE_AI_API_KEY: ""
  AZURE_OPENAI_API_KEY: ""
  AZURE_OPENAI_ENDPOINT: ""
  COHERE_API_KEY: ""

  # S3 configuration (optional)
  AWS_ACCESS_KEY_ID: ""
  AWS_SECRET_ACCESS_KEY: ""
  AWS_REGION: "us-east-1"
  S3_BUCKET: ""

  # Monitoring (optional)
  JAEGER_ENDPOINT: "http://jaeger-service:14268/api/traces"

  # SMTP configuration (optional)
  SMTP_HOST: ""
  SMTP_PORT: "587"
  SMTP_USERNAME: ""
  SMTP_PASSWORD: ""
